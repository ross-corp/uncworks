# Hydration init-container image.
FROM golang:1.25-bookworm AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /hydration ./cmd/hydration

FROM golang:1.25-bookworm AS runtime
# golang base already has git, curl, ca-certificates
# Install devbox for workspace dependency management
RUN curl -fsSL https://get.jetify.com/devbox | bash -s -- -f

COPY --from=builder /hydration /usr/local/bin/hydration
WORKDIR /workspace
ENTRYPOINT ["hydration"]
