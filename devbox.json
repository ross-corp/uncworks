{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/main/.schema/devbox.schema.json",
  "_comment_soft_serve": "Also install soft-serve: go install github.com/charmbracelet/soft-serve/cmd/soft@latest",
  "packages": [
    "go@latest",
    "nodejs@22",
    "k0sctl@latest",
    "kubectl@latest",
    "postgresql@16",
    "lefthook@latest",
    "golangci-lint@latest",
    "buf@latest",
    "grpcurl@latest",
    "kubernetes-helm@latest",
    "temporal-cli@latest",
    "go-task@latest",
    "setup-envtest@latest",
    "wails@latest"
  ],
  "shell": {
    "init_hook": [
      "lefthook install 2>/dev/null || true",
      "echo '==> AOT development environment ready'",
      "echo '    Run \"task\" to see available commands'"
    ],
    "scripts": {
      "test": "task test",
      "test:go": "task test:go",
      "test:e2e": "task test:e2e",
      "test:web": "task test:web",
      "test:ext": "task test:extension",
      "test:shared": "task test:shared",
      "build": "task build",
      "build:web": "task build:web",
      "proto:gen": "task proto:gen",
      "k0s:setup": "task k0s:setup",
      "k0s:teardown": "task k0s:teardown",
      "k0s:crd": "task k0s:crd",
      "dev:web": "task dev:web",
      "install": "task install",
      "lint": "task lint"
    }
  }
}
