# values.homelab.yaml.example — Template for deploying UNCWORKS to a homelab k0s cluster.
# Copy to values.homelab.yaml (gitignored) and fill in your environment values.
#
# Usage:
#   helm upgrade --install uncworks ./deploy/helm/aot \
#     -n uncworks --create-namespace \
#     -f deploy/helm/values.homelab.yaml

# Temporal — in-cluster dev server
temporal:
  host: "temporal-dev.uncworks.svc.cluster.local:7233"
  namespace: "default"

# LiteLLM proxy deployed in-cluster
llm:
  baseUrl: "http://litellm.uncworks.svc.cluster.local:4000"
  masterKeySecretName: "litellm-master-key"

# GitHub token for cloning private repos
github:
  tokenSecretName: "github-token"

# All images built locally and imported into k0s containerd (amd64, pullPolicy: Never)
# Tag must match what was imported — see tasks/homelab.yml.example for the build procedure
images:
  controlplane:
    repository: docker.io/library/aot-controlplane
    tag: homelab
    pullPolicy: Never
  init:
    repository: docker.io/library/aot-init
    tag: homelab
    pullPolicy: Never
  sidecar:
    repository: docker.io/library/aot-sidecar
    tag: homelab
    pullPolicy: Never
  agent:
    repository: docker.io/library/aot-agent
    tag: homelab
    pullPolicy: Never
  web:
    repository: docker.io/library/aot-web
    tag: homelab
    pullPolicy: Never
  bff:
    repository: docker.io/library/aot-bff
    tag: homelab
    pullPolicy: Never

# Controller
controller:
  replicas: 1
  retentionDays: 7
  resources:
    requests:
      cpu: 50m
      memory: 64Mi
    limits:
      cpu: 250m
      memory: 128Mi

# Worker
worker:
  replicas: 1
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 1000m
      memory: 512Mi

# API server
apiserver:
  replicas: 1
  port: 50055
  service:
    type: NodePort
    nodePort: 30055   # pick an available port in 30000-32767
  # Path to local-path-provisioner data on the node.
  # k0s default: /opt/local-path-provisioner
  # k3s default: /var/lib/rancher/k3s/storage
  pvcDataHostPath: "/opt/local-path-provisioner"
  pvcDataRunAsRoot: true
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 256Mi

# Web dashboard
web:
  enabled: true
  replicas: 1
  port: 3000
  service:
    type: NodePort
    nodePort: 30300   # pick an available port in 30000-32767
  resources:
    requests:
      cpu: 50m
      memory: 64Mi
    limits:
      cpu: 500m
      memory: 256Mi

# BFF disabled — nginx web deployment handles proxying
bff:
  enabled: false

# soft-serve disabled for homelab (optional)
softServe:
  enabled: false

# Tailscale ingress — set hostnames to your tailnet (requires Tailscale operator in cluster)
ingress:
  tailscale:
    enabled: true
    webHostname: "uncworks.your-tailnet.ts.net"
    apiserverHostname: "uncworks-api.your-tailnet.ts.net"

logLevel: "info"
