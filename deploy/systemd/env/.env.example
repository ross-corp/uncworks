# Copy this file to create per-service env files:
#   cp .env.example temporal.env
#   cp .env.example controller.env
#   etc.
#
# Each service reads its own .env file. Variables not relevant to a service are ignored.

# --- Paths (all services) ---
AOT_PROJECT_DIR=/path/to/uncworks
KUBECONFIG=/path/to/uncworks/kubeconfig

# --- Temporal (aot-temporal.service) ---
TEMPORAL_DB_FILENAME=/path/to/uncworks/.temporal.db

# --- Controller (aot-controller.service) ---
TEMPORAL_HOST=localhost:7233
METRICS_ADDR=:8095

# --- Worker (aot-worker.service) ---
# TEMPORAL_HOST=localhost:7233  (same as controller)
AOT_AGENT_IMAGE=aot-agent:local
AOT_SIDECAR_IMAGE=aot-sidecar:local
AOT_INIT_IMAGE=aot-init:local

# --- API Server (aot-apiserver.service) ---
LISTEN_ADDR=:50055
# TEMPORAL_HOST=localhost:7233  (same as controller)

# API key for authenticating requests (strongly recommended for production).
# When set, all non-health endpoints require: Authorization: Bearer <key>
# AOT_API_KEY=your-secret-key-here

# Comma-separated list of allowed CORS origins.
# Defaults to localhost:3000,localhost:5173 for development.
# Set to your production domain(s) in production.
# AOT_ALLOWED_ORIGINS=https://app.example.com

# GitHub webhook signature validation (required for secure webhook handling).
# GITHUB_WEBHOOK_SECRET=your-webhook-secret

# --- Web UI (aot-web.service) ---
# Uses vite on port 3000
# VITE_API_URL=http://localhost:50055
# VITE_API_KEY=your-secret-key-here  (same as AOT_API_KEY)
