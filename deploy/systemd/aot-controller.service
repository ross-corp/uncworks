[Unit]
Description=AOT Controller
After=aot-temporal.service
Requires=aot-temporal.service
PartOf=aot-cluster.target

[Service]
Type=simple
EnvironmentFile=%h/uncworks/deploy/systemd/env/controller.env
WorkingDirectory=%h/uncworks
ExecStart=%h/uncworks/bin/controller
Restart=on-failure
RestartSec=5

[Install]
WantedBy=aot-cluster.target
