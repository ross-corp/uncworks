{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@bufbuild/protobuf": ["./node_modules/@bufbuild/protobuf"],
      "@bufbuild/protobuf/*": ["./node_modules/@bufbuild/protobuf/*"]
    }
  },
  "include": ["src"]
}
